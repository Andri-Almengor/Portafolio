{
  "name": "andrick-portfolio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "build": "npm --workspace client run build",
    "test": "npm --workspace server test",
    "setup:sheets": "npm --workspace server run setup:sheets",
    "sync:sheets": "npm --workspace server run sync:sheets",
    "authorize:drive": "npm --workspace server run authorize:drive"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
